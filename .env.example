# Copy to .env and fill in real secrets.

# Choose: pushover, email, both, or none.
BETTING_DELIVERY=pushover

# Optional runtime inputs.
BETTING_CANDIDATE_SOURCE=norsk-tipping-live
BETTING_NT_EVENTS_PER_SPORT=35
# BETTING_NT_EARLIEST_START=2026-05-15T08:00
BETTING_INPUT_CSV=/home/morten/Prog/betting/examples/norsk_tipping_candidates.csv
BETTING_RESEARCH_SOURCES=/home/morten/Prog/betting/examples/research_sources.txt
# BETTING_REFERENCE_ODDS_CSV=/home/morten/Prog/betting/reference_odds.csv
# BETTING_DATE=2026-05-15

# OpenAI 4-agent workflow.
# Requires paid API access and OPENAI_API_KEY.
BETTING_ENABLE_AI=true
BETTING_OPENAI_MODEL=gpt-5.5
OPENAI_API_KEY=

# Pushover iPhone delivery.
BETTING_PUSHOVER_TOKEN=
BETTING_PUSHOVER_USER=

# SMTP email delivery.
BETTING_SMTP_HOST=
BETTING_SMTP_PORT=587
BETTING_SMTP_USERNAME=
BETTING_SMTP_PASSWORD=
BETTING_EMAIL_FROM=
BETTING_EMAIL_TO=
